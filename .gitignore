# uv / Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# uv lock file is intentionally committed — remove this line if you don't want that
# uv.lock

# Nuitka build artifacts
*.build/
*.dist/
*.onefile-build/
build_*.log
run_*.log

# Vendored CHIRP clone — its own git repo, pinned by commit and bundled at
# build time; not committed into the VRP repo. Clone it with:
#   git clone --depth=1 https://github.com/kk7ds/chirp.git
/chirp/

# CHIRP image files (radio memory dumps — personal data)
*.img

# Test cache
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Dev run logs (grid preview, smoke output)
logs/

# Debug serial trace (written to CWD by main.py --debug during a clone)
serial-trace.txt

# Radio reverse-engineering artifacts (e.g. the KG-UV96M effort): USB/serial
# packet captures, CSV exports, process-id artifacts, and scratch analysis /
# screenshots. These hold personal radio data (channels/call signs) and are
# working files, not source — keep them local. (*.img already covered above.)
*.pcap
*.pid
*.png
csv.txt
_decoded.txt
_usbpcap.pid
