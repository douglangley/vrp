# uv / Python
.venv/
# Dedicated framework-Python venv for the py2app build (setup.py) — py2app
# can't introspect uv's statically-linked managed Python, so this is built
# from a separate `brew install python@3.11` interpreter. Not the normal dev
# venv; recreated on demand, never committed.
.venv-py2app/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# uv lock file is intentionally committed — remove this line if you don't want that
# uv.lock

# Nuitka build artifacts
*.build/
*.dist/
*.onefile-build/
build_*.log
run_*.log

# Vendored CHIRP clone — its own git repo, pinned by commit and bundled at
# build time; not committed into the VRP repo. Clone it with:
#   git clone --depth=1 https://github.com/kk7ds/chirp.git
/chirp/

# CHIRP image files (radio memory dumps — personal data)
*.img

# Test cache
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Dev run logs (grid preview, smoke output)
logs/

# Debug serial trace (written to CWD by main.py --debug during a clone)
serial-trace.txt

# Reverse-engineering / scratch working files kept in the repo root (e.g. the
# KG-UV96M effort): USB/serial packet captures, process-id artifacts, and one-off
# screenshots/exports. Personal working data — not part of the app.
*.pcap
*.pid
RadioSettings.png
csv.txt
